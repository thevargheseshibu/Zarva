import inspEn   from "@inspection/translations/en";
import payEn    from "@payment/translations/en";
import notifEn  from "@notifications/translations/en";
import workerEn from "@worker/translations/en";
import custEn   from "@customer/translations/en";
import sharedEn from "./en"; // common_* error_* button_* keys only

