{
  "expo": {
    "name": "Zarva",
    "slug": "zarva",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "com.zarva.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Zarva needs your location to find nearby workers"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "googleServicesFile": "./google-services.json",
      "package": "com.zarva.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/messaging",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Zarva needs your location in the background to track job progress and notify you of nearby requests.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C9A84C"
        }
      ],
      "expo-audio",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Zarva to access your camera to capture material receipts."
        }
      ]
    ]
  }
}